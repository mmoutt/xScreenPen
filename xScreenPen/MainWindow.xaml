<Window x:Class="xScreenPen.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="xScreenPen"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="NoResize"
        WindowState="Maximized"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        Loaded="Window_Loaded">
    
    
    <Grid x:Name="MainGrid" Background="#01FFFFFF">
        <InkCanvas x:Name="inkCanvas" 
                   Background="Transparent"
                   Cursor="Pen"
                   EditingMode="Ink"
>
            <InkCanvas.DefaultDrawingAttributes>
                <DrawingAttributes Color="#FFFFFFFF" Width="4" Height="4" FitToCurve="True" IgnorePressure="False"/>
            </InkCanvas.DefaultDrawingAttributes>
        </InkCanvas>

        <!-- Floating Toolbar -->
        <StackPanel x:Name="FloatingToolbar"
                    Orientation="Vertical"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,30">
            
            <!-- Secondary Panel (Colors & Sizes) - Expands from BtnPen -->
            <Border x:Name="SecondaryPanel"
                    Background="{StaticResource ToolbarBackground}"
                    BorderBrush="{StaticResource ToolbarBorder}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Padding="8,4"
                    Margin="0,0,0,5"
                    HorizontalAlignment="Center"
                    Visibility="Collapsed"
                    RenderTransformOrigin="0.5,1">
                <Border.RenderTransform>
                    <ScaleTransform x:Name="SecondaryPanelScale" ScaleX="1" ScaleY="1"/>
                </Border.RenderTransform>
                <StackPanel Orientation="Horizontal">
                    <!-- Colors -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnColorWhite" Style="{StaticResource ToolButtonStyle}" Width="32" Height="32"
                                Click="BtnColor_Click" Tag="#FFFFFFFF" ToolTip="白色">
                            <Ellipse Width="16" Height="16" Fill="#FFFFFFFF"/>
                        </Button>
                        <Button x:Name="BtnColorBlack" Style="{StaticResource ToolButtonStyle}" Width="32" Height="32"
                                Click="BtnColor_Click" Tag="#FF000000" ToolTip="黑色">
                            <Ellipse Width="16" Height="16" Fill="#FF000000"/>
                        </Button>
                        <Button x:Name="BtnColorRed" Style="{StaticResource ToolButtonStyle}" Width="32" Height="32"
                                Click="BtnColor_Click" Tag="#FFFF0000" ToolTip="红色">
                            <Ellipse Width="16" Height="16" Fill="#FFFF0000"/>
                        </Button>
                        <Button x:Name="BtnColorBlue" Style="{StaticResource ToolButtonStyle}" Width="32" Height="32"
                                Click="BtnColor_Click" Tag="#FF0066FF" ToolTip="蓝色">
                            <Ellipse Width="16" Height="16" Fill="#FF0066FF"/>
                        </Button>
                        <Button x:Name="BtnColorGreen" Style="{StaticResource ToolButtonStyle}" Width="32" Height="32"
                                Click="BtnColor_Click" Tag="#FF00CC00" ToolTip="绿色">
                            <Ellipse Width="16" Height="16" Fill="#FF00CC00"/>
                        </Button>
                        <Button x:Name="BtnColorYellow" Style="{StaticResource ToolButtonStyle}" Width="32" Height="32"
                                Click="BtnColor_Click" Tag="#FFFFCC00" ToolTip="黄色">
                            <Ellipse Width="16" Height="16" Fill="#FFFFCC00"/>
                        </Button>
                    </StackPanel>

                    <Rectangle Width="1" Height="30" Fill="#60FFFFFF" Margin="8,0"/>

                    <!-- Pen Size -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button x:Name="BtnSizeSmall" Style="{StaticResource ToolButtonStyle}" Width="32"
                                Click="BtnSize_Click" Tag="2" ToolTip="细">
                            <Ellipse Width="6" Height="6" Fill="White"/>
                        </Button>
                        <Button x:Name="BtnSizeMedium" Style="{StaticResource ToolButtonStyle}" Width="32"
                                Click="BtnSize_Click" Tag="4" ToolTip="中">
                            <Ellipse Width="10" Height="10" Fill="White"/>
                        </Button>
                        <Button x:Name="BtnSizeLarge" Style="{StaticResource ToolButtonStyle}" Width="32"
                                Click="BtnSize_Click" Tag="6" ToolTip="粗">
                            <Ellipse Width="14" Height="14" Fill="White"/>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Main Toolbar Row -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                <!-- Floating Ball (Expand/Collapse & Drag) -->
                <Border x:Name="FloatingBall"
                        Background="{StaticResource ToolbarBackground}"
                        BorderBrush="{StaticResource ToolbarBorder}"
                        BorderThickness="1"
                        CornerRadius="24"
                        Width="48" Height="48"
                        Cursor="Hand"
                        MouseDown="FloatingBall_MouseDown"
                        MouseUp="FloatingBall_MouseUp"
                        TouchDown="FloatingBall_TouchDown"
                        TouchUp="FloatingBall_TouchUp"
                        TouchMove="FloatingBall_TouchMove"
                        ToolTip="点击展开/收起，拖动移动">
                    <Path x:Name="FloatingBallIcon" 
                          Data="M3,17.25V21h3.75L17.81,9.94l-3.75-3.75L3,17.25z M20.71,7.04c0.39-0.39,0.39-1.02,0-1.41l-2.34-2.34c-0.39-0.39-1.02-0.39-1.41,0l-1.83,1.83l3.75,3.75L20.71,7.04z"
                          Fill="#FF00AAFF" Stretch="Uniform" Width="18" Height="18"
                          HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                
                <!-- Expandable Toolbar Content -->
                <Border x:Name="ToolbarContent"
                        Background="{StaticResource ToolbarBackground}"
                        BorderBrush="{StaticResource ToolbarBorder}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="4,4"
                        Margin="5,0,0,0"
                        RenderTransformOrigin="0,0.5">
                    <Border.RenderTransform>
                        <ScaleTransform x:Name="ToolbarContentScale" ScaleX="1" ScaleY="1"/>
                    </Border.RenderTransform>
                    <StackPanel Orientation="Horizontal">
                        <!-- Mouse Mode -->
                        <Button x:Name="BtnToggle" Style="{StaticResource ToolButtonStyle}" 
                                Click="BtnToggle_Click" ToolTip="鼠标模式 (M)">
                            <Path x:Name="ToggleIcon" Data="M13.64,21.97C13.14,22.21,12.54,22,12.31,21.5L10.13,16.76L7.62,18.78C7.45,18.92,7.24,19,7,19A1,1,0,0,1,6,18V3A1,1,0,0,1,7,2C7.24,2,7.47,2.09,7.64,2.23L19.14,11.74C19.64,12.12,19.74,12.82,19.36,13.32C19.18,13.56,18.91,13.72,18.62,13.76L14.15,14.5L16.31,19.22C16.54,19.72,16.31,20.32,15.81,20.55L13.64,21.97Z" 
                                  Fill="White" Stretch="Uniform" Width="20" Height="20"/>
                        </Button>

                        <!-- Pen Button (with secondary expand) -->
                        <Button x:Name="BtnPen" Style="{StaticResource ToolButtonStyle}" 
                                Click="BtnPen_Click" ToolTip="画笔选项 (P)">
                            <Path x:Name="PenIcon" Data="M3,17.25V21h3.75L17.81,9.94l-3.75-3.75L3,17.25z M20.71,7.04c0.39-0.39,0.39-1.02,0-1.41l-2.34-2.34c-0.39-0.39-1.02-0.39-1.41,0l-1.83,1.83l3.75,3.75L20.71,7.04z" 
                                  Fill="White" Stretch="Uniform" Width="20" Height="20"/>
                        </Button>
                        
                        <!-- Eraser Button -->
                        <Button x:Name="BtnEraser" Style="{StaticResource ToolButtonStyle}" 
                                Click="BtnEraser_Click" ToolTip="橡皮擦 (E)">
                            <Path x:Name="EraserIcon" Data="M15.14,3C14.63,3 14.12,3.2 13.73,3.59L2.59,14.73C1.81,15.5 1.81,16.77 2.59,17.56L5.03,20H12.69L21.41,11.27C22.2,10.5 22.2,9.23 21.41,8.44L16.56,3.59C16.17,3.2 15.65,3 15.14,3M17,18L15,20H22V18" 
                                  Fill="White" Stretch="Uniform" Width="20" Height="20"/>
                        </Button>

                        <!-- Clear -->
                        <Button x:Name="BtnClear" Style="{StaticResource ToolButtonStyle}" 
                                Click="BtnClear_Click" ToolTip="清屏 (C)">
                            <Path Data="M6,19c0,1.1,0.9,2,2,2h8c1.1,0,2-0.9,2-2V7H6V19z M19,4h-3.5l-1-1h-5l-1,1H5v2h14V4z" 
                                  Fill="White" Stretch="Uniform" Width="20" Height="20"/>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>
        </StackPanel>

        <!-- Full-screen Grid for Drag (Ink-Canvas pattern) -->
        <Grid x:Name="GridForFloatingBarDraging" 
              Background="#01000000" 
              Visibility="Collapsed"
              MouseMove="GridDrag_MouseMove" 
              MouseUp="GridDrag_MouseUp"
              TouchMove="GridDrag_TouchMove"
              TouchUp="GridDrag_TouchUp"/>

        <!-- Current Tool Indicator -->
        <Border x:Name="ToolIndicator"
                Background="#80000000"
                CornerRadius="5"
                Padding="10,5"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="20"
                Visibility="Collapsed">
            <TextBlock x:Name="ToolIndicatorText" Foreground="White" FontSize="14"/>
        </Border>
    </Grid>
</Window>
